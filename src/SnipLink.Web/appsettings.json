{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=sniplink;Username=sniplink;Password=sniplink",
    "Redis": "localhost:6379"
  },
  "SnipLink": {
    "BaseUrl": "http://localhost:8080",
    "CodeLength": 6,
    "CacheTtl": "01:00:00",
    "IpHashSalt": "change-me-in-production",
    "TopReferrersLimit": 10,
    "Seed": false,
    "EnableSwagger": false
  }
}
